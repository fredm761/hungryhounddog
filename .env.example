# HungryHoundDog — Environment Variables
# Copy to .env and modify as needed:  cp .env.example .env
#
# Docker Compose reads .env automatically from the project root.
# These values are used in docker-compose.yml and by the services.

# --- OpenSearch ---
OPENSEARCH_JAVA_OPTS=-Xms4g -Xmx4g

# --- Grafana ---
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=hungryhound

# --- Ingestion API ---
OPENSEARCH_HOST=opensearch
OPENSEARCH_PORT=9200
INDEX_PREFIX=hungryhounddog-events
