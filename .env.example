# =============================================================================
# HungryHoundDog — Environment Variables Template
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to version control — it contains secrets.
# =============================================================================

# --- OpenSearch ---
OPENSEARCH_HOST=localhost
OPENSEARCH_PORT=9200
OPENSEARCH_INDEX_PREFIX=hungryhounddog

# --- Grafana ---
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme

# --- Ollama (Local LLM) ---
OLLAMA_HOST=localhost
OLLAMA_PORT=11434
OLLAMA_MODEL=phi3:mini

# --- ChromaDB (Vector Store) ---
CHROMADB_HOST=localhost
CHROMADB_PORT=8000
CHROMADB_COLLECTION=security_logs

# --- Sensor Configuration ---
SENSOR_BRAIN_ENDPOINT=https://192.168.1.100:8080/ingest
SENSOR_SHIP_INTERVAL_SECONDS=10
SENSOR_HEALTH_CHECK_INTERVAL_SECONDS=60

# --- Alert Webhooks (optional) ---
ALERT_WEBHOOK_URL=
ALERT_WEBHOOK_ENABLED=false

# --- External SSD Mount Point ---
SSD_MOUNT_PATH=/mnt/ssd
